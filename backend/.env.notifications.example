# ─── backend/.env (añadir estas variables) ────────────────────────────────────
# Copiar en backend/.env y rellenar con tus valores

# ── Notificaciones por email ──────────────────────────────────────────────────
NOTIFICATIONS_ENABLED=false       # Cambiar a true para activar

# Opción A: Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx  # App password de Google, NO tu contraseña normal
SMTP_FROM=tu-email@gmail.com

# Opción B: Outlook / Office365
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_TLS=true
# SMTP_USER=tu-email@empresa.com
# SMTP_PASSWORD=tu-contraseña

# URL de la app (para incluir links en los emails)
APP_URL=http://localhost:5173


# ─── Leer estas variables en backend/app/core/config.py ──────────────────────
# Si usas Pydantic Settings, añade los campos:
#
# class Settings(BaseSettings):
#     ...
#     NOTIFICATIONS_ENABLED: bool = False
#     SMTP_HOST:     str = ""
#     SMTP_PORT:     int = 587
#     SMTP_TLS:      bool = True
#     SMTP_USER:     str = ""
#     SMTP_PASSWORD: str = ""
#     SMTP_FROM:     str = ""
#     APP_URL:       str = ""
#
#     model_config = SettingsConfigDict(env_file=".env", extra="ignore")


# ─── Cómo obtener un App Password en Gmail ────────────────────────────────────
# 1. Ir a https://myaccount.google.com/security
# 2. Activar Verificación en 2 pasos (si no está activa)
# 3. Buscar "Contraseñas de aplicaciones"
# 4. Crear una nueva contraseña para "Correo" / "Windows"
# 5. Copiar la contraseña generada (16 caracteres) en SMTP_PASSWORD


# ─── Automatizar recordatorios diarios con Windows Task Scheduler ─────────────
# Crear una tarea programada que ejecute este script cada día a las 08:00:
#
# start_reminders.ps1:
# ---------------------
# $token = "Bearer TU_JWT_TOKEN_ADMIN"
# $url   = "http://localhost:8000/api/v1/schedule/send-reminders?days_ahead=1&days_ahead=3&days_ahead=7"
# Invoke-RestMethod -Method POST -Uri $url -Headers @{Authorization=$token}
#
# En Task Scheduler:
#   Acción: PowerShell.exe -File "C:\ruta\start_reminders.ps1"
#   Desencadenador: Diariamente a las 08:00